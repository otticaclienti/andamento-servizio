# APPLICAZIONE - OC - Environment Variables

# Claude AI (per generazione nota settimanale)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Cron job secret (per proteggere /api/weekly-sync)
CRON_SECRET=your-secret-here

# Database (quando si aggiunge un DB reale)
# DATABASE_URL=postgresql://user:pass@host:5432/db

# GHL (configurazione globale opzionale)
# GHL_WEBHOOK_SECRET=your-webhook-secret
